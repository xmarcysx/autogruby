# ============================================================
# Auto Gruby — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# --- Supabase ---
# Find these in your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose this publicly, server-only
# Used for admin operations (seeding, migrations)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://autogruby.pl
NEXT_PUBLIC_SITE_NAME=Auto Gruby

# --- Contact (TODO: replace with real data) ---
NEXT_PUBLIC_PHONE=+48 000 000 000
NEXT_PUBLIC_EMAIL=kontakt@autogruby.pl
NEXT_PUBLIC_ADDRESS=ul. Przykładowa 1, 43-100 Tychy

# --- Google Maps (TODO: replace with real embed key) ---
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-maps-api-key

# --- Analytics (TODO: add when ready) ---
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
